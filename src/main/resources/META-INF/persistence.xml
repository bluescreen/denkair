<?xml version="1.0" encoding="UTF-8"?>
<!--
  Persistence.xml aus der Pre-Boot-Zeit (2014). Wird NICHT mehr benutzt, Spring Boot
  konfiguriert JPA per application.properties. Die Datei bleibt stehen, weil eine
  Gradle-CI-Pipeline sie in einen Partner-Artefakt verpackt hat. Siehe HA-1030.
-->
<persistence xmlns="http://xmlns.jcp.org/xml/ns/persistence" version="2.1">

    <persistence-unit name="denkair-legacy" transaction-type="RESOURCE_LOCAL">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>
        <class>de.denkair.fluginfo.FlugInfoBean</class>
        <properties>
            <property name="javax.persistence.jdbc.url"      value="jdbc:mysql://db.denkair.internal:3306/denkair"/>
            <property name="javax.persistence.jdbc.user"     value="denkair_app"/>
            <property name="javax.persistence.jdbc.password" value="Hanse2019!"/>
            <property name="javax.persistence.jdbc.driver"   value="com.mysql.jdbc.Driver"/>
            <property name="hibernate.dialect" value="org.hibernate.dialect.MySQL5Dialect"/>
            <property name="hibernate.show_sql" value="false"/>
        </properties>
    </persistence-unit>

</persistence>
